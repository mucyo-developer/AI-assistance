# Virtual environment and Python cache
/Lib
/include
/share
/__pycache__
/*.pyc
/ngrok.exe

# Ignore virtual environment patterns in subdirectories
*/Lib
*/include
*/share
*/__pycache__
*/*.pyc

# Diabetes memory data (binary files that should not be committed)
/Scripts/diabetes_memory/

# Deployment-specific files
/Scripts/DEPLOYMENT.md
/Scripts/DEPLOYMENT_STATUS.md
/Scripts/Dockerfile
/Scripts/docker-compose.yml
/Scripts/README.md
/Scripts/requirements.txt
/Scripts/run_production.py
/Scripts/test_deployment.py
/Scripts/web_diabetes_assistant.py

# Logs and temporary files
*.log
*.tmp
*.temp

# Environment variables (keep .env.example but ignore .env)
.env